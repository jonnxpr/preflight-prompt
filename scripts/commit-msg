#!/usr/bin/env python3

"""
Git commit-msg hook — Conventional Commits enforcement.

Pattern follows partner-governance pre-commit hook style
(shebang, run() -> int, MARKER constant, chain to backup).

Validates that commit messages follow Conventional Commits format
per .github/copilot-commit-message-instructions.md.
"""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path


MARKER = "preflight-prompt-commit-msg-hook"

CC_TYPES = (
    "feat", "fix", "docs", "style", "refactor",
    "perf", "test", "build", "ci", "chore", "revert",
)

CC_REGEX = re.compile(
    r"^(" + "|".join(CC_TYPES) + r")"
    r"(\([a-z][a-z0-9-]*\))?"
    r"!?"
    r": "
    r".+"
)

MERGE_REGEX = re.compile(r"^Merge ")
REVERT_REGEX = re.compile(r"^Revert ")


def validate_message(msg: str) -> tuple[bool, str]:
    """Return (ok, reason) for the first line of the commit message."""
    first_line = msg.strip().split("\n")[0].strip()

    if not first_line:
        return False, "Commit message is empty."

    # Allow merge and revert commits generated by git itself
    if MERGE_REGEX.match(first_line) or REVERT_REGEX.match(first_line):
        return True, ""

    if not CC_REGEX.match(first_line):
        allowed = ", ".join(CC_TYPES)
        return False, (
            f"Commit message does not follow Conventional Commits.\n"
            f"Expected: <type>(<scope>): <subject>\n"
            f"Allowed types: {allowed}\n"
            f"Got: {first_line}"
        )

    if len(first_line) > 100:
        return False, (
            f"Subject line exceeds 100 characters ({len(first_line)} chars).\n"
            f"Got: {first_line}"
        )

    return True, ""


def run() -> int:
    hook_path = Path(__file__).resolve()
    backup_hook = hook_path.with_name("commit-msg.user-backup")

    if len(sys.argv) < 2:
        print("Usage: commit-msg <message-file>", file=sys.stderr)
        return 1

    msg_file = Path(sys.argv[1])
    if not msg_file.exists():
        print(f"Message file not found: {msg_file}", file=sys.stderr)
        return 1

    msg = msg_file.read_text(encoding="utf-8", errors="ignore")
    ok, reason = validate_message(msg)

    if not ok:
        print(f"[commit-msg hook] {reason}", file=sys.stderr)
        return 1

    # Chain to user backup hook if present
    if backup_hook.exists():
        chained = subprocess.run([str(backup_hook), str(msg_file)])
        return chained.returncode

    return 0


if __name__ == "__main__":
    raise SystemExit(run())
